{
  "properties": {
    "description": "Consumes WMATA real-time events from Azure Event Hub and routes them to Bronze lakehouse Delta tables in schema wmata.",
    "source": {
      "type": "AzureEventHub",
      "properties": {
        "connectionString": "<EVENT_HUB_CONNECTION_STRING>",
        "eventHubName": "wmata-realtime",
        "consumerGroup": "fabric-eventstream",
        "dataFormat": "Json"
      }
    },
    "destinations": [
      {
        "type": "Lakehouse",
        "properties": {
          "workspaceId": "c030c477-6e50-4334-8fcb-fd032f8870b9",
          "lakehouseId": "82a4dd04-28a2-4ac4-acab-254953df7edb",
          "schema": "wmata",
          "table": "rail_predictions",
          "inputSerialization": {
            "type": "Json",
            "properties": {
              "encoding": "UTF8"
            }
          }
        }
      },
      {
        "type": "Lakehouse",
        "properties": {
          "workspaceId": "c030c477-6e50-4334-8fcb-fd032f8870b9",
          "lakehouseId": "82a4dd04-28a2-4ac4-acab-254953df7edb",
          "schema": "wmata",
          "table": "bus_positions",
          "inputSerialization": {
            "type": "Json",
            "properties": {
              "encoding": "UTF8"
            }
          }
        }
      },
      {
        "type": "Lakehouse",
        "properties": {
          "workspaceId": "c030c477-6e50-4334-8fcb-fd032f8870b9",
          "lakehouseId": "82a4dd04-28a2-4ac4-acab-254953df7edb",
          "schema": "wmata",
          "table": "rail_incidents",
          "inputSerialization": {
            "type": "Json",
            "properties": {
              "encoding": "UTF8"
            }
          }
        }
      },
      {
        "type": "Lakehouse",
        "properties": {
          "workspaceId": "c030c477-6e50-4334-8fcb-fd032f8870b9",
          "lakehouseId": "82a4dd04-28a2-4ac4-acab-254953df7edb",
          "schema": "wmata",
          "table": "bus_incidents",
          "inputSerialization": {
            "type": "Json",
            "properties": {
              "encoding": "UTF8"
            }
          }
        }
      }
    ],
    "routing": {
      "description": "Route records by _feed_name into WMATA schema tables in Bronze lakehouse.",
      "rules": [
        {
          "when": "_feed_name == 'rail_predictions'",
          "destinationTable": "wmata.rail_predictions"
        },
        {
          "when": "_feed_name == 'bus_positions'",
          "destinationTable": "wmata.bus_positions"
        },
        {
          "when": "_feed_name == 'rail_incidents'",
          "destinationTable": "wmata.rail_incidents"
        },
        {
          "when": "_feed_name == 'bus_incidents'",
          "destinationTable": "wmata.bus_incidents"
        }
      ]
    }
  }
}
